set -euo pipefail
mkdir -p ".direnv"

# Load Nix profile if nix is not in PATH
if ! command -v nix &> /dev/null; then
  if [ -f "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" ]; then
    source /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
  elif [ -f "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
    source "$HOME/.nix-profile/etc/profile.d/nix.sh"
  fi
fi

# nix-direnv (pinned)
if ! has nix_direnv_version || ! nix_direnv_version 3.1.0; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.1.0/direnvrc" \
    "sha256-yMJ2OVMzrFaDPn7q8nCBZFRYpL/f0RcHzhmw/i6btJM="
fi

use flake

# uv layout (auto-sync on pyproject changes)
layout_uv() {
  [[ -f "pyproject.toml" ]] || return 0
  local cache_dir=".direnv/uv"
  mkdir -p "$cache_dir"
  watch_file pyproject.toml
  watch_file uv.lock
  local new_pyproject_hash=$(sha256sum pyproject.toml 2>/dev/null | awk '{print $1}')
  local old_pyproject_hash=$(cat "$cache_dir/pyproject.toml.hash" 2>/dev/null || echo "")
  if [[ ! -f "uv.lock" ]] || [[ "$new_pyproject_hash" != "$old_pyproject_hash" ]]; then
    echo "Syncing Python dependencies..."
    uv sync --quiet
    echo "$new_pyproject_hash" > "$cache_dir/pyproject.toml.hash"
  fi
  PATH_add ".venv/bin"
}
layout uv

# node layout (auto-install on ui/package.json changes)
layout_node() {
  [[ -f "ui/package.json" ]] || return 0
  local cache_dir=".direnv/node"
  mkdir -p "$cache_dir"
  watch_file ui/package.json
  watch_file ui/package-lock.json
  local new_hash=$(sha256sum ui/package.json 2>/dev/null | awk '{print $1}')
  local old_hash=$(cat "$cache_dir/package.json.hash" 2>/dev/null || echo "")
  if [[ ! -d "ui/node_modules" ]] || [[ "$new_hash" != "$old_hash" ]]; then
    echo "Installing UI dependencies..."
    (cd ui && npm install --quiet)
    echo "$new_hash" > "$cache_dir/package.json.hash"
  fi
}
layout node

if [[ -f ".env" ]]; then
  dotenv
fi
